# Application
APP_NAME=documentragsystem
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8100

# S3 / MinIO
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=documents
S3_REGION=us-east-1

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_UPLOAD_TOPIC=document.upload
KAFKA_DLQ_TOPIC=document.upload.dlq
KAFKA_CONSUMER_GROUP=ingestion-worker

# Vector DB (Chroma)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=documents

# Ingestion
MAX_RETRIES=3
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
ALLOWED_EXTENSIONS=.pdf,.docx,.csv

# Idempotency store (SQLite path for local dev)
IDEMPOTENCY_DB_PATH=./data/idempotency.db
